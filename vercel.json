{
  "version": 2,
  "builds": [
    { "src": "frontend/*.html", "use": "@vercel/static" },
    { "src": "frontend/*.css",  "use": "@vercel/static" },
    { "src": "frontend/*.js",   "use": "@vercel/static" },
    { "src": "frontend/*.svg",  "use": "@vercel/static" },
    { "src": "frontend/*.png",  "use": "@vercel/static" },
    { "src": "frontend/*.jpg",  "use": "@vercel/static" },
    { "src": "backend/api/*.py","use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/",                    "dest": "/frontend/index.html" },
    { "src": "/favicon.ico", "dest": "/frontend/favicon.ico" },
    { "src": "/favicon-32x32.png", "dest": "/frontend/favicon-32x32.png" },
    { "src": "/favicon-16x16.png", "dest": "/frontend/favicon-16x16.png" }
    { "src": "/admin",               "dest": "/frontend/admin.html" },
    { "src": "/admin.html",          "dest": "/frontend/admin.html" },
    { "src": "/style.css",           "dest": "/frontend/style.css"  },
    { "src": "/app.js",              "dest": "/frontend/app.js"     },
    { "src": "/subway-logo.svg",     "dest": "/frontend/subway-logo.svg" },
    { "src": "/subway-logo.png",     "dest": "/frontend/subway-logo.png" },
    { "src": "/sample-receipt.jpg",  "dest": "/frontend/sample-receipt.jpg" },
    { "src": "/api/settings",        "dest": "/backend/api/settings.py" },
    { "src": "/api/submit",          "dest": "/backend/api/submit.py"   },
    { "src": "/api/admin/entries/([^/]+)", "dest": "/backend/api/admin.py" },
    { "src": "/api/admin/(.*)",      "dest": "/backend/api/admin.py"    },
    { "src": "/api/admin/draw/pool", "dest": "/backend/api/admin.py"    },
    { "src": "/api/admin/draw",      "dest": "/backend/api/admin.py"    }
  ]
}
